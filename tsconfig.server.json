{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "lib": ["esnext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true,
    "typeRoots": ["./node_modules/@types"],
    "paths": {
      "@server/*": ["./server/*"]
    }
  },
  "include": ["server.ts", "server/**/*.ts", "src/types/**/*.ts", "*.d.ts"],
  "exclude": ["node_modules", ".next"]
}
